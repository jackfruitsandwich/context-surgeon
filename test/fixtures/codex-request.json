{
  "model": "gpt-4.1",
  "instructions": "You are a helpful coding assistant.",
  "input": [
    {
      "type": "message",
      "role": "developer",
      "content": [{ "type": "input_text", "text": "Always be concise." }]
    },
    {
      "type": "message",
      "role": "user",
      "content": [{ "type": "input_text", "text": "Read the file src/app.ts" }]
    },
    {
      "type": "message",
      "role": "assistant",
      "content": [{ "type": "output_text", "text": "I'll read that file for you." }]
    },
    {
      "type": "function_call",
      "name": "read_file",
      "arguments": "{\"path\": \"src/app.ts\"}",
      "call_id": "call_abc123"
    },
    {
      "type": "function_call_output",
      "call_id": "call_abc123",
      "output": "import express from 'express';\n\nconst app = express();\n\napp.get('/', (req, res) => {\n  res.send('Hello World');\n});\n\napp.listen(3000, () => {\n  console.log('Server running on port 3000');\n});\n\nexport default app;"
    },
    {
      "type": "message",
      "role": "assistant",
      "content": [{ "type": "output_text", "text": "Here's the content of src/app.ts. It's a basic Express server." }]
    },
    {
      "type": "message",
      "role": "user",
      "content": [{ "type": "input_text", "text": "Now add error handling middleware" }]
    }
  ],
  "tools": [
    {
      "type": "function",
      "function": {
        "name": "read_file",
        "description": "Read a file",
        "parameters": { "type": "object", "properties": { "path": { "type": "string" } } }
      }
    }
  ],
  "stream": true,
  "tool_choice": "auto"
}
